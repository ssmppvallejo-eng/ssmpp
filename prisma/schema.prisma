generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Descriptor {
  id              Int       @id @default(autoincrement())
  title String
  value Int
  description     String
  indicatorId     Int
  indicator       Indicator @relation(fields: [indicatorId], references: [id])
  assignmentIndicatorDescriptors AssignmentIndicatorDescriptor[]
}

model Assignment {
  id            Int        @id @default(autoincrement())
  ownerId       Int
  dimensionId   Int
  assignmentDate DateTime?
  submissionDate DateTime?
  status        IndicatorStatus @default(PENDIENTE)

  owner         User       @relation(fields: [ownerId], references: [id])
  dimension     Dimension  @relation(fields: [dimensionId], references: [id])

  indicators    AssignmentIndicator[]
  assignedUsers UserAssignTo[]
}

model AssignmentIndicator {
  id            Int        @id @default(autoincrement())
  indicatorId   Int
  assignmentId  Int
  
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  indicator     Indicator  @relation(fields: [indicatorId], references: [id])

  descriptorAssignments       AssignmentIndicatorDescriptor[]
}

model AssignmentIndicatorDescriptor {
  assignmentIndicatorId Int
  descriptorId              Int
  valueAssigned                 Int
  evaluationValue Int?
  note                  String?
  evidenceName          String?
  evidenceUrl           String?
  addComment  Boolean @default(false)
  addEvidence Boolean @default(false)
  complete              Boolean @default(false)

  descriptor                Descriptor              @relation(fields: [descriptorId], references: [id])
  assignmentIndicator   AssignmentIndicator @relation(fields: [assignmentIndicatorId], references: [id])

  @@id([assignmentIndicatorId, descriptorId])
}

model Component {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  title        String
  description  String?
  dimensionId  Int

  dimension    Dimension @relation(fields: [dimensionId], references: [id])
  judgements   Judgement[]
}

model Indicator {
  id             Int       @id @default(autoincrement())
  code           String    @unique
  description    String
  judgementId    Int

  judgement      Judgement @relation(fields: [judgementId], references: [id])

  descriptors        Descriptor[]
  assignments    AssignmentIndicator[]
  templates      TemplateIndicator[]
}

model Judgement {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  title       String
  description String?
  componentId Int

  component   Component @relation(fields: [componentId], references: [id])
  indicators  Indicator[]
}

model Postgraduate {
  id              Int       @id @default(autoincrement())
  level           Level
  knowledgeArea   Area
  title           String

  templates       Template[]
  users           UserPostgraduate[]
}

model Dimension {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  title       String
  description String?

  components  Component[]
  assignments Assignment[]
}

model Template {
  id            Int       @id @default(autoincrement())
  name          String
  description   String?
  postgraduateId Int

  postgraduate  Postgraduate @relation(fields: [postgraduateId], references: [id])
  indicators    TemplateIndicator[]
}

model TemplateIndicator {
  templateId  Int
  indicatorId Int

  template    Template  @relation(fields: [templateId], references: [id])
  indicator   Indicator @relation(fields: [indicatorId], references: [id])

  @@id([templateId, indicatorId])
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  image         String?
  name          String?
  role          Role     @default(ESTUDIANTE)
  active        Boolean  @default(false)

  assignments   Assignment[]
  assignedTo    UserAssignTo[]
  postgraduates UserPostgraduate[]
}

model UserAssignTo {
  assignmentId Int
  userId       Int

  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])

  @@id([assignmentId, userId])
}

model UserPostgraduate {
  userId         Int
  postgraduateId Int

  user           User         @relation(fields: [userId], references: [id])
  postgraduate   Postgraduate @relation(fields: [postgraduateId], references: [id])

  @@id([userId, postgraduateId])
}

enum Area {
  CIENCIAS_EXACTAS
  CIENCIAS_NATURALES_Y_AGROPECUARIAS
  CIENCIAS_DE_LA_SALUD
  CIENCIAS_DE_LA_EDUCACION_Y_HUMANIDADES
  CIENCIAS_SOCIALES_Y_ADMINISTRATIVAS
  INGENIERIA_Y_TECNOLOGIAS
}

enum IndicatorStatus {
  PENDIENTE
  EN_PROCESO
  ENVIADO
  EN_REVISION
  COMPLETADO
}

enum Level {
  ESPECIALIDADES
  MAESTRIAS
  DOCTORADOS
  ESPECIALIDADES_MEDICAS
}

enum Role {
  ADMINISTRADOR
  ESTUDIANTE
  COORDINADOR
  PROFESOR
  EVALUADOR
}

